{
  "controls": {
    "title": "🌍 Global Trade Controls",
    "controls": [
      {
        "type": "separator",
        "label": "🌐 Earth Surface"
      },
      {
        "type": "slider",
        "label": "Normal Map Strength",
        "uniform": "u_normal_strength",
        "min": 0,
        "max": 3,
        "step": 0.05,
        "default": 1
      },
      {
        "type": "slider",
        "label": "Night Lights Intensity",
        "uniform": "u_night_intensity",
        "min": 0,
        "max": 4,
        "step": 0.1,
        "default": 1.5
      },
      {
        "type": "slider",
        "label": "Terminator Softness",
        "uniform": "u_terminator_softness",
        "min": 0.02,
        "max": 0.5,
        "step": 0.01,
        "default": 0.15
      },
      {
        "type": "separator",
        "label": "☀️ Sun / Lighting"
      },
      {
        "type": "slider",
        "label": "Sun Rotation Speed",
        "uniform": "u_sun_rot_speed",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "default": 0.15
      },
      {
        "type": "slider",
        "label": "Sun Elevation",
        "uniform": "u_sun_elevation",
        "min": -0.5,
        "max": 0.5,
        "step": 0.01,
        "default": 0.1
      },
      {
        "type": "separator",
        "label": "📷 Camera"
      },
      {
        "type": "slider",
        "label": "Camera Distance",
        "uniform": "u_camera_distance",
        "min": 1.5,
        "max": 8,
        "step": 0.1,
        "default": 3
      },
      {
        "type": "toggle",
        "label": "Auto Rotate",
        "uniform": "u_auto_rotate",
        "default": true
      },
      {
        "type": "slider",
        "label": "Rotation Speed",
        "uniform": "u_auto_rot_speed",
        "min": 0,
        "max": 0.5,
        "step": 0.01,
        "default": 0.1
      },
      {
        "type": "slider",
        "label": "Mouse Sensitivity",
        "uniform": "u_sensitivity",
        "min": 0.5,
        "max": 3,
        "step": 0.1,
        "default": 1.5
      },
      {
        "type": "separator",
        "label": "🔄 Trade Flows"
      },
      {
        "type": "toggle",
        "label": "Show Trade Arcs",
        "uniform": "u_show_trade",
        "default": true
      },
      {
        "type": "slider",
        "label": "Max Arcs",
        "uniform": "u_max_arcs",
        "min": 10,
        "max": 1000,
        "step": 10,
        "default": 1000
      },
      {
        "type": "slider",
        "label": "Trade Threshold",
        "uniform": "u_trade_threshold",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "default": 0
      },
      {
        "type": "slider",
        "label": "Arc Glow",
        "uniform": "u_trade_glow",
        "min": 0,
        "max": 2,
        "step": 0.05,
        "default": 1
      },
      {
        "type": "slider",
        "label": "Pulse Speed",
        "uniform": "u_pulse_speed",
        "min": 0,
        "max": 3,
        "step": 0.1,
        "default": 1
      },
      {
        "type": "toggle",
        "label": "Show Labels",
        "uniform": "u_show_labels",
        "default": true
      },
      {
        "type": "separator",
        "label": "🛰️ Orbits & Grid"
      },
      {
        "type": "toggle",
        "label": "Show Orbits",
        "uniform": "u_show_orbits",
        "default": true
      },
      {
        "type": "slider",
        "label": "Orbit Glow",
        "uniform": "u_orbit_glow",
        "min": 0,
        "max": 2,
        "step": 0.05,
        "default": 0.8
      },
      {
        "type": "slider",
        "label": "Trail Length",
        "uniform": "u_trail_length",
        "min": 0.05,
        "max": 0.8,
        "step": 0.01,
        "default": 0.3
      },
      {
        "type": "slider",
        "label": "Animation Speed",
        "uniform": "u_anim_speed",
        "min": 0,
        "max": 3,
        "step": 0.1,
        "default": 1
      },
      {
        "type": "toggle",
        "label": "Show Grid",
        "uniform": "u_show_grid",
        "default": true
      },
      {
        "type": "toggle",
        "label": "Show Axes",
        "uniform": "u_show_axes",
        "default": false
      }
    ],
    "width": 320,
    "height": 300
  }
}