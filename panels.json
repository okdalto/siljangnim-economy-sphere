{
  "controls": {
    "title": "🛰️ Orbital Visualization",
    "controls": [
      {
        "type": "separator",
        "label": "📷 Camera"
      },
      {
        "type": "slider",
        "label": "Camera Distance",
        "uniform": "u_camera_distance",
        "min": 1.5,
        "max": 10,
        "step": 0.1,
        "default": 3
      },
      {
        "type": "slider",
        "label": "Mouse Sensitivity",
        "uniform": "u_sensitivity",
        "min": 0.3,
        "max": 5,
        "step": 0.1,
        "default": 1.5
      },
      {
        "type": "toggle",
        "label": "Auto Rotate",
        "uniform": "u_auto_rotate",
        "default": true
      },
      {
        "type": "slider",
        "label": "Rotation Speed",
        "uniform": "u_auto_rot_speed",
        "min": 0,
        "max": 1,
        "step": 0.01,
        "default": 0.1
      },
      {
        "type": "separator",
        "label": "🛰️ Orbits"
      },
      {
        "type": "toggle",
        "label": "Show Orbits",
        "uniform": "u_show_orbits",
        "default": true
      },
      {
        "type": "slider",
        "label": "Orbit Glow",
        "uniform": "u_orbit_glow",
        "min": 0,
        "max": 2,
        "step": 0.05,
        "default": 0.8
      },
      {
        "type": "slider",
        "label": "Trail Length",
        "uniform": "u_trail_length",
        "min": 0.05,
        "max": 0.8,
        "step": 0.01,
        "default": 0.3
      },
      {
        "type": "slider",
        "label": "Animation Speed",
        "uniform": "u_anim_speed",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "default": 1
      },
      {
        "type": "separator",
        "label": "🌐 Data Grid"
      },
      {
        "type": "toggle",
        "label": "Show Grid",
        "uniform": "u_show_grid",
        "default": true
      },
      {
        "type": "toggle",
        "label": "Show Axes (XYZ)",
        "uniform": "u_show_axes",
        "default": false
      }
    ],
    "width": 320,
    "height": 300
  }
}